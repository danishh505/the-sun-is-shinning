name: Auto Compile cl.exe dan Publish ke Releases
on: [push, workflow_dispatch]

# Memberikan izin agar bot GitHub bisa membuat Release dan mengunggah file
permissions:
  contents: write

jobs:
  compile_and_release:
    runs-on: windows-latest

    steps:
    - name: Ambil Code dari Repositori
      uses: actions/checkout@v4

    # 1. Mengekstrak file jika ada zip baru
    - name: Mengekstrak redsun.zip
      run: |
        if (Test-Path redsun.zip) {
            Expand-Archive -Path redsun.zip -DestinationPath . -Force
        }

    # 2. Menyiapkan lingkungan compiler cl.exe
    - name: Setup MSVC (cl.exe)
      uses: ilammy/msvc-dev-cmd@v1

    # 3. Proses Compile (Sudah diperbaiki dengan flag Unicode agar tidak error)
    - name: Compile dengan cl.exe
      run: |
        cl.exe /EHsc /DUNICODE /D_UNICODE RedSun.cpp

    # 4. LANGKAH BARU: Membuat Tag & Upload .EXE langsung ke Halaman Releases
    - name: Upload ke GitHub Releases
      uses: softprops/action-gh-release@v2
      with:
        tag_name: v1.0.${{ github.run_number }}
        name: RedSun Build v1.0.${{ github.run_number }}
        body: |
          Aplikasi RedSun.exe berhasil di-compile otomatis dari Android.
          ID Kompilasi: ${{ github.run_number }}
        draft: false
        prerelease: false
        files: RedSun.exe
